<section class="py-16 px-6 md:px-12 bg-secondary/20">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-3xl font-bold mb-8 font-['Playfair_Display'] text-foreground">{{ section.settings.title }}</h2>
    <div class="flex gap-8 items-center justify-center">
      <div class="flex flex-col items-center">
        <div class="relative">
          <div class="w-24 h-24 rounded-full border-4 border-primary/30 bg-secondary/20 flex items-center justify-center shadow-lg shadow-primary/20">
            <span class="text-4xl font-bold text-primary font-['Playfair_Display'] drop-shadow-lg">{{ 'now' | date: '%H' }}</span>
          </div>
          <div class="absolute inset-0 rounded-full border-2 border-primary animate-pulse opacity-50"></div>
        </div>
        <span class="text-xs text-primary font-semibold mt-2 tracking-wider">HOURS</span>
      </div>
      <div class="flex flex-col items-center">
        <div class="relative">
          <div class="w-24 h-24 rounded-full border-4 border-primary/30 bg-secondary/20 flex items-center justify-center shadow-lg shadow-primary/20">
            <span class="text-4xl font-bold text-primary font-['Playfair_Display'] drop-shadow-lg">{{ 'now' | date: '%M' }}</span>
          </div>
          <div class="absolute inset-0 rounded-full border-2 border-primary animate-pulse opacity-50"></div>
        </div>
        <span class="text-xs text-primary font-semibold mt-2 tracking-wider">MINUTES</span>
      </div>
      <div class="flex flex-col items-center">
        <div class="relative">
          <div class="w-24 h-24 rounded-full border-4 border-primary/30 bg-secondary/20 flex items-center justify-center shadow-lg shadow-primary/20">
            <span class="text-4xl font-bold text-primary font-['Playfair_Display'] drop-shadow-lg">{{ 'now' | date: '%S' }}</span>
          </div>
          <div class="absolute inset-0 rounded-full border-2 border-primary animate-pulse opacity-50"></div>
        </div>
        <span class="text-xs text-primary font-semibold mt-2 tracking-wider">SECONDS</span>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Countdown Timer",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Drop Vanishes In"
    }
  ]
}
{% endschema %}</content>
<parameter name="filePath">/workspaces/theme-fixer/sections/countdown.liquid