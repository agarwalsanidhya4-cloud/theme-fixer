<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main class="pt-24">
  <section class="px-6 md:px-12 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="text-4xl font-bold mb-8 font-['Playfair_Display']">Your Cart</h1>

      {% if cart.item_count > 0 %}
        <div class="grid gap-4">
          {% for item in cart.items %}
            <div class="grid grid-cols-4 gap-4 border border-border rounded-xl p-4 items-center">
              <img src="{{ item.image | img_url: '100x100' }}" alt="{{ item.title }}" class="w-24 h-24 object-cover rounded" />
              <div class="col-span-2">
                <a href="{{ item.url }}" class="text-lg font-semibold text-foreground">{{ item.title }}</a>
                <p class="text-sm text-muted-foreground">{{ item.variant_title }}</p>
              </div>
              <div class="text-right">
                <p class="text-lg font-bold">{{ item.line_price | money }}</p>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="mt-8 flex flex-col items-end gap-4">
          <p class="text-xl text-foreground">Subtotal: <span class="font-bold">{{ cart.total_price | money }}</span></p>
          <a href="/checkout" class="bg-primary text-primary-foreground px-6 py-4 rounded-full font-bold">Checkout</a>
        </div>
      {% else %}
        <p class="text-muted-foreground">Your cart is empty.</p>
      {% endif %}
    </div>
  </section>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>