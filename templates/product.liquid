<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main class="pt-24">
  <section class="px-6 md:px-12 py-12">
    {% if product %}
      <div class="max-w-7xl mx-auto grid lg:grid-cols-2 gap-10 items-start">
        <div class="rounded-2xl overflow-hidden border border-border shadow-2xl">
          <img src="{{ product.featured_image | img_url: '2048x2048' }}" alt="{{ product.title }}" class="w-full object-cover" />
        </div>
        <div class="space-y-6">
          <p class="text-sm text-primary font-semibold uppercase">{{ product.vendor }}</p>
          <h1 class="text-4xl font-bold font-['Playfair_Display']">{{ product.title }}</h1>
          <div class="text-xl text-primary font-bold">{{ product.price | money }}</div>
          <div class="text-muted-foreground">{{ product.description }}</div>
          <form action="/cart/add" method="post" class="grid gap-4">
            {% if product.variants.size > 1 %}
              <label class="text-sm">Size</label>
              <select name="id" class="rounded-lg border border-border bg-background p-3">
                {% for variant in product.variants %}
                  <option value="{{ variant.id }}">{{ variant.title }}{% unless variant.available %} (Sold out){% endunless %}</option>
                {% endfor %}
              </select>
            {% else %}
              <input type="hidden" name="id" value="{{ product.variants.first.id }}" />
            {% endif %}
            <button class="bg-primary text-primary-foreground font-bold py-4 rounded-full">Add to cart</button>
          </form>
        </div>
      </div>
    {% else %}
      <p class="text-center text-muted-foreground">Product not found.</p>
    {% endif %}
  </section>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>