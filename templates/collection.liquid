<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main class="pt-24">
  <section class="px-6 md:px-12 py-12">
    {% if collection %}
      <div class="max-w-7xl mx-auto">
        <div class="mb-8">
          <h1 class="text-4xl font-bold font-['Playfair_Display']">{{ collection.title }}</h1>
          <p class="text-muted-foreground mt-2">{{ collection.description }}</p>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-6">
          {% for product in collection.products %}
            <a href="{{ product.url }}" class="group block rounded-lg overflow-hidden border border-border hover:border-primary transition-all">
              <img src="{{ product.featured_image | img_url: '720x720' }}" alt="{{ product.title }}" class="w-full h-72 object-cover group-hover:scale-105 transition-transform" />
              <div class="p-4 bg-secondary/20">
                <h3 class="text-lg font-semibold">{{ product.title }}</h3>
                <p class="text-sm text-primary font-bold">{{ product.price | money }}</p>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <p class="text-center text-muted-foreground">Collection not found.</p>
    {% endif %}
  </section>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>