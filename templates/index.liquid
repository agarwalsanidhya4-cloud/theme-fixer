<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main>
  <section class="pt-20 md:pt-24 pb-8 px-6 md:px-12">
    <div class="max-w-7xl mx-auto">
      <div class="grid md:grid-cols-2 gap-8 md:gap-12 items-start">
        <div class="relative">
          <div class="sticky top-24">
            <div class="relative rounded-2xl overflow-hidden border-2 border-border shadow-2xl">
              <div class="absolute top-4 left-4 bg-primary text-primary-foreground px-4 py-2 rounded-full font-bold text-sm z-10">TODAY'S DROP</div>
              <div class="absolute top-4 right-4 bg-secondary/70 backdrop-blur-sm px-4 py-2 rounded-full text-xs z-10 flex items-center gap-2">
                <span class="text-primary">✨</span>
                <span>Exclusive</span>
              </div>
              <img src="https://images.unsplash.com/photo-1756483515151-468b4b5ca1ba?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&q=80&w=1200" alt="Royal Peacock Silk Lehenga" class="w-full h-[500px] md:h-[700px] object-cover" />
              <div class="absolute inset-0 bg-gradient-to-t from-background/20 via-transparent to-transparent"></div>
            </div>
          </div>
        </div>

        <div class="space-y-6 md:pt-8">
          <div>
            <p class="text-primary text-sm font-semibold mb-2 tracking-wider">Handwoven Heritage • Limited Edition</p>
            <h2 class="text-4xl md:text-5xl font-bold mb-4 font-['Playfair_Display'] leading-tight">Royal Peacock Silk Lehenga</h2>
            <p class="text-muted-foreground leading-relaxed">An exquisite turquoise and gold lehenga set featuring intricate zardozi work and hand-embroidered peacock motifs. This masterpiece takes 240+ hours of skilled craftsmanship.</p>
          </div>

          <div class="flex items-baseline gap-4">
            <span class="text-5xl font-bold text-primary font-['Playfair_Display']">₹24,999</span>
            <span class="text-2xl text-muted-foreground line-through">₹34,999</span>
            <span class="bg-accent text-accent-foreground px-3 py-1 rounded-full text-sm font-bold">SAVE 29%</span>
          </div>

          <div class="bg-secondary/40 border-2 border-border rounded-xl p-6">
            <p class="text-center text-sm text-muted-foreground mb-4">This Drop Vanishes In:</p>
            <div class="flex gap-4 items-center justify-center">
              <div class="flex flex-col items-center">
                <div class="bg-primary/10 border-2 border-primary rounded-lg px-4 py-3 min-w-[70px] text-center">
                  <span class="text-3xl font-bold text-primary font-['Playfair_Display']">23</span>
                </div>
                <span class="text-xs text-muted-foreground mt-1">HOURS</span>
              </div>
              <span class="text-2xl text-primary font-bold">:</span>
              <div class="flex flex-col items-center">
                <div class="bg-primary/10 border-2 border-primary rounded-lg px-4 py-3 min-w-[70px] text-center">
                  <span class="text-3xl font-bold text-primary font-['Playfair_Display']">45</span>
                </div>
                <span class="text-xs text-muted-foreground mt-1">MINUTES</span>
              </div>
              <span class="text-2xl text-primary font-bold">:</span>
              <div class="flex flex-col items-center">
                <div class="bg-primary/10 border-2 border-primary rounded-lg px-4 py-3 min-w-[70px] text-center">
                  <span class="text-3xl font-bold text-primary font-['Playfair_Display']">12</span>
                </div>
                <span class="text-xs text-muted-foreground mt-1">SECONDS</span>
              </div>
            </div>
          </div>

          <div class="bg-muted/50 rounded-xl p-6 border border-border">
            <div class="w-full">
              <div class="flex justify-between items-center mb-2">
                <span class="text-sm text-muted-foreground">Fabric Left</span>
                <span class="text-sm font-semibold text-primary">Only 15 meters left!</span>
              </div>
              <div class="h-3 bg-muted rounded-full overflow-hidden border border-border">
                <div class="h-full bg-primary transition-all duration-300 relative" style="width: 25%">
                  <div class="absolute inset-0 bg-primary/20 animate-pulse"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="grid grid-cols-2 gap-4">
            <div class="bg-muted/50 rounded-lg p-4 border border-border">
              <p class="text-xs text-muted-foreground mb-1 uppercase">Fabric</p>
              <p class="text-sm font-medium">Pure Banarasi Silk with Gold Zari</p>
            </div>
            <div class="bg-muted/50 rounded-lg p-4 border border-border">
              <p class="text-xs text-muted-foreground mb-1 uppercase">Work</p>
              <p class="text-sm font-medium">Hand Embroidery, Zardozi, Stone Work</p>
            </div>
            <div class="bg-muted/50 rounded-lg p-4 border border-border">
              <p class="text-xs text-muted-foreground mb-1 uppercase">Occasion</p>
              <p class="text-sm font-medium">Weddings, Grand Celebrations</p>
            </div>
            <div class="bg-muted/50 rounded-lg p-4 border border-border">
              <p class="text-xs text-muted-foreground mb-1 uppercase">Delivery</p>
              <p class="text-sm font-medium">10-12 Days (Made-to-Order)</p>
            </div>
          </div>

          <button class="hidden md:flex w-full bg-primary hover:bg-primary/80 text-primary-foreground font-bold py-5 rounded-xl text-lg transition-all hover:scale-[1.02] hover:shadow-2xl hover:shadow-primary/20 items-center justify-center gap-3">
            <span>📦</span>
            SECURE YOUR PIECE NOW
          </button>

          <div class="flex items-center justify-center gap-2 text-sm text-muted-foreground animate-bounce pt-4">
            <span>Scroll to see past drops</span>
            <span>↓</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-6 md:px-12 py-8">
    <div class="max-w-7xl mx-auto">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 py-8">
        <div class="flex flex-col items-center text-center gap-3 p-6 bg-muted/50 rounded-lg border border-border hover:border-primary/30 transition-all">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="text-primary">✨</span>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">Handcrafted in Surat</h4>
            <p class="text-xs text-muted-foreground">Artisan quality</p>
          </div>
        </div>
        <div class="flex flex-col items-center text-center gap-3 p-6 bg-muted/50 rounded-lg border border-border hover:border-primary/30 transition-all">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="text-primary">🔒</span>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">100% Prepaid Secure</h4>
            <p class="text-xs text-muted-foreground">Encrypted checkout</p>
          </div>
        </div>
        <div class="flex flex-col items-center text-center gap-3 p-6 bg-muted/50 rounded-lg border border-border hover:border-primary/30 transition-all">
          <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center">
            <span class="text-primary">✓</span>
          </div>
          <div>
            <h4 class="text-sm font-semibold mb-1">Made-to-Order</h4>
            <p class="text-xs text-muted-foreground">Exclusive for you</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-6 md:px-12 bg-secondary/30">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-4xl md:text-5xl font-bold mb-3 font-['Playfair_Display']">MISSED FOREVER</h2>
        <p class="text-muted-foreground">These exclusive pieces are gone. Don't let today's drop slip away.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
        {% for product in collections.all.products limit: 7 %}
          <div class="relative group overflow-hidden rounded-lg aspect-[3/4] border border-border">
            <img src="{{ product.featured_image | img_url: '600x' }}" alt="{{ product.title }}" class="w-full h-full object-cover grayscale" />
            <div class="absolute inset-0 bg-secondary/60 flex flex-col items-center justify-center">
              <div class="bg-primary text-primary-foreground px-6 py-3 rounded-lg rotate-[-12deg] font-['Playfair_Display'] font-bold text-lg border-4 border-background shadow-xl">SOLD OUT</div>
              <p class="text-foreground mt-4 text-sm">{{ product.created_at | date: "%b %d" }}</p>
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="text-center mt-12">
        <a href="/pages/archive" class="inline-flex items-center gap-3 bg-primary hover:bg-primary/80 text-primary-foreground px-8 py-4 rounded-xl font-semibold transition-all hover:scale-105">
          View Full Archive
          <span>→</span>
        </a>
      </div>
    </div>
  </section>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>

<div id="shopify-section-sticky-buy-button" class="shopify-section">
  {% section 'sticky-buy-button' %}
</div>