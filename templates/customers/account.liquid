<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main class="pt-24 px-6 md:px-12">
  <div class="max-w-xl mx-auto py-12">
    <h1 class="text-4xl font-bold font-['Playfair_Display'] text-center mb-6">My Account</h1>

    {% if customer %}
      <p class="text-muted-foreground mb-4">Welcome back, {{ customer.first_name }} {{ customer.last_name }}!</p>
      <div class="space-y-3 text-right">
        <a href="/account/logout" class="inline-block px-6 py-3 rounded-full border border-border text-sm">Log out</a>
        <a href="/account/orders" class="inline-block px-6 py-3 rounded-full bg-primary hover:bg-primary/80 text-primary-foreground">Order History</a>
      </div>
    {% else %}
      <p class="text-muted-foreground mb-4">Please log in to view your account details.</p>
      <a href="/account/login" class="inline-block bg-primary text-primary-foreground px-6 py-3 rounded-full">Login</a>
    {% endif %}
  </div>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>