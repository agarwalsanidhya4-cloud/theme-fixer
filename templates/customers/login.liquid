<div id="shopify-section-header" class="shopify-section">
  {% section 'header' %}
</div>

<main class="pt-24 px-6 md:px-12">
  <div class="max-w-xl mx-auto py-12">
    <h1 class="text-4xl font-bold font-['Playfair_Display'] text-center mb-6">Login</h1>
    <form method="post" action="/account/login" class="space-y-4">
      <input type="email" name="customer[email]" placeholder="Email" required class="w-full p-4 bg-secondary/20 border border-border rounded-lg" />
      <input type="password" name="customer[password]" placeholder="Password" required class="w-full p-4 bg-secondary/20 border border-border rounded-lg" />
      <button type="submit" class="w-full bg-primary text-primary-foreground font-bold py-4 rounded-full">Sign in</button>
    </form>
  </div>
</main>

<div id="shopify-section-footer" class="shopify-section">
  {% section 'footer' %}
</div>